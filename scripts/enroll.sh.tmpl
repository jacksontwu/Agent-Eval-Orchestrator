#!/usr/bin/env bash
# Agent Eval Orchestrator - worker enroll script (idempotent, re-runnable).
set -euo pipefail

CONTROLLER_URL="{{CONTROLLER_URL}}"
AEO_BOT_USERNAME="{{BOT_USERNAME}}"
AEO_BOT_PASSWORD="{{BOT_PASSWORD}}"
WORKER_ID="{{WORKER_ID}}"
WORK_DIR="${AEO_WORKER_DIR:-$HOME/aeo-worker}"

echo "[enroll] controller: ${CONTROLLER_URL}  worker: ${WORKER_ID}"

# 1. Ensure uv is installed (official installer; worker has outbound internet).
if ! command -v uv >/dev/null 2>&1 && [ ! -x "$HOME/.local/bin/uv" ]; then
  echo "[enroll] installing uv ..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi
export PATH="$HOME/.local/bin:$PATH"

# 2. Ensure Docker is present (do not auto-install; just warn).
if ! command -v docker >/dev/null 2>&1; then
  echo "[enroll] WARNING: docker not found; install Docker before running evaluations." >&2
fi

# 3. Pull the project + Harbor code bundle from the controller (no GitHub dependency).
mkdir -p "${WORK_DIR}"
echo "[enroll] logging in as bot ..."
LOGIN_RESPONSE="$(curl -fsSL \
  -H "Content-Type: application/json" \
  -d "{\"username\":\"${AEO_BOT_USERNAME}\",\"password\":\"${AEO_BOT_PASSWORD}\"}" \
  "${CONTROLLER_URL}/api/auth/login")"
ACCESS_TOKEN="$(python3 -c 'import json,sys; print(json.load(sys.stdin)["accessToken"])' <<< "${LOGIN_RESPONSE}")"

echo "[enroll] downloading code bundle ..."
curl -fsSL -H "Authorization: Bearer ${ACCESS_TOKEN}" \
  "${CONTROLLER_URL}/api/workers/code-bundle" -o "${WORK_DIR}/code-bundle.tar.gz"
tar -xzf "${WORK_DIR}/code-bundle.tar.gz" -C "${WORK_DIR}"

# 4. Install Python dependencies.
cd "${WORK_DIR}/backend"
uv sync

# 5. Start the worker daemon (self-registers via /api/workers/register).
echo "[enroll] starting worker daemon ..."
nohup uv run python -m app.worker.daemon \
  --controller-url "${CONTROLLER_URL}" \
  --worker-id "${WORKER_ID}" \
  --bot-username "${AEO_BOT_USERNAME}" \
  --bot-password "${AEO_BOT_PASSWORD}" \
  >> "${WORK_DIR}/worker.log" 2>&1 &

echo "[enroll] done. tailing logs: tail -f ${WORK_DIR}/worker.log"
