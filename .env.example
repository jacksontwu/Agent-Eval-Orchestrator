# 复制为 .env 后按需修改:cp .env.example .env
# 该文件放在项目根目录,后端(uvicorn / alembic / worker)无论从哪个目录启动都会自动读取,
# 运维脚本(scripts/*.sh)也会在启动前 source 它。

# 共享认证 token(必填)。所有接口(除 /api/health)都需要它;
# worker 用请求头 X-AEO-Token,enroll.sh 用 ?token= 传递。
AEO_TOKEN=change-me-shared-token

# 运行根目录:archives / controller(sqlite 默认在 <root>/controller/aeo.db)/ imported-jobs 等。
AEO_SHARED_ROOT=runtime

# 监听地址与端口。
AEO_HOST=0.0.0.0
AEO_PORT=8790

# 可选:Harbor 仓库路径(执行器与 viewer 使用)。
# AEO_HARBOR_REPO=/root/projects/harbor

# 可选:前端构建产物路径(单端口托管时指向它)。
# AEO_FRONTEND_DIST=frontend/dist

# 可选:显式数据库 URL(不设则由 AEO_SHARED_ROOT 推导)。
# DATABASE_URL=sqlite:///runtime/controller/aeo.db

# 可选(谨慎):本地开发免 token。设为 1 时允许无 token 启动。
# AEO_ALLOW_NO_AUTH=1

# 可选:禁用后台编排线程(测试/调试用)。
# AEO_DISABLE_ORCHESTRATION=1
